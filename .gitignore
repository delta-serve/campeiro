# Campeiro - .gitignore

# Dados e logs locais
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep

# Configurações sensíveis
config/.env
config/.env-dev
*.secret
*.key

# Certificados
*.pem
*.crt
*.p12
*.pfx
certs/

# Backups e temporários
*.backup
*.bak
*.old
*.tmp
*.temp
~*

# Scripts de uso pontual / análises locais
analises/
scripts/add_dashboard_filters.py
scripts/fix_renavam_dashboard.py
scripts/fix_adaptive_polling_redis.sh

# Streams de teste / desabilitados
streams/teste.yaml
disabled/

# Arquivos JSON de retorno / análise local
retorno_*.json

# Opencode
opencode.json.old

# Cache de ferramentas
.ruff_cache/

# Sistema operacional
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
