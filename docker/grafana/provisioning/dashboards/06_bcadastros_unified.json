      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        { "expr": "max(bcpf_couchdb_request_duration_ms)", "legendFormat": "CPF - Fetch", "refId": "A" },
        { "expr": "max(bcpf_write_duration_ms)", "legendFormat": "CPF - Write", "refId": "B" },
        { "expr": "max(bcpf_cycle_duration_ms)", "legendFormat": "CPF - Total", "refId": "C" },
        { "expr": "max(bcnpj_couchdb_request_duration_ms)", "legendFormat": "CNPJ - Fetch", "refId": "D" },
        { "expr": "max(bcnpj_write_duration_ms)", "legendFormat": "CNPJ - Write", "refId": "E" },
        { "expr": "max(bcnpj_cycle_duration_ms)", "legendFormat": "CNPJ - Total", "refId": "F" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto",
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 15000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPF" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "CNPJ" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "values": ["value", "min", "max", "mean", "last"]
        }
      }
    },
