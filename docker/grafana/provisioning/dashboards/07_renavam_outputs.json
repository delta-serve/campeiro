          "legendFormat": "Entregues",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        },
        {
          "expr": "(clamp_min(sum(rate(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[1m])) - sum(rate(renavam_rabbitmq_sentry_sent_total{empresa=\"MULTIWAY\", path!~\".*processors\\.2.*\"}[1m])), 0)) or sum(rate(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[1m]))",
          "legendFormat": "Descartados",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
