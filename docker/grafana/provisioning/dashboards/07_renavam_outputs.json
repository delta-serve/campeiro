      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by (label) (rate(output_error{stream=\"ab_retorno_renavam\", label=~\"$bento_label\"}[5m])) / clamp_min(sum by (label) (rate(output_batch_sent{stream=\"ab_retorno_renavam\", label=~\"$bento_label\"}[5m])), 0.001) * 100",
          "legendFormat": "{{label}}",
