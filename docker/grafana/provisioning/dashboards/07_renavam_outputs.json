  "title": "RENAVAM - Outputs & SLA",
  "uid": "renavam_outputs_sla",
  "version": 1,
  "panels": [
    {
      "title": "── VISÃO GERAL POR OUTPUT ──",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Entregue",
      "description": "Total consolidado de eventos entregues em todos os outputs. Para MULTIWAY, reflete o rate limit de 10k/h.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(renavam_messages_sent_total{destination=~\"$destination\"}[$__range]))",
          "refId": "A",
          "legendFormat": "Total",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "title": "SENTRY (RabbitMQ)",
      "description": "Eventos entregues via RabbitMQ SENTRY (MULTIWAY + 7LAN). Para MULTIWAY, máximo 10k/h por rate limit.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 5, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(renavam_rabbitmq_sentry_sent_total{destination=~\"$destination\", path!~\".*processors\\.2.*\"}[$__range])) or sum(increase(renavam_rabbitmq_sentry_sent_total{empresa=\"7LAN\", path!~\".*processors\\.2.*\"}[$__range]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "title": "NAVEGANTES (HTTP)",
      "description": "Eventos entregues via HTTP PROTENET (empresa PROTENET).",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 9, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(renavam_http_navegantes_sent_total{destination=~\"$destination\"}[$__range]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "title": "SSP/GO (Kafka)",
      "description": "Eventos entregues via Kafka para SSP/GO.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 13, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(renavam_kafka_sspgo_sent_total{destination=~\"$destination\"}[$__range]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "title": "Rate Limited (MULTIWAY)",
      "description": "Eventos MULTIWAY descartados pelo rate limit (10k/h). Quando rate limit bloqueia 100% e série sent fica stale, mostra elegíveis como fallback.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 3, "x": 17, "y": 1 },
      "targets": [
        {
          "expr": "(clamp_min(sum(increase(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[$__range])) - sum(increase(renavam_rabbitmq_sentry_sent_total{empresa=\"MULTIWAY\", path!~\".*processors\\.2.*\"}[$__range])), 0)) or sum(increase(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[$__range]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "title": "Health Status",
      "description": "Score de saúde baseado em taxa de erro e latência.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "clamp_max(clamp_min(100 - (sum(rate(output_error{stream=\"ab_retorno_renavam\", label=~\"$bento_label\"}[5m])) / clamp_min(sum(rate(output_batch_sent{stream=\"ab_retorno_renavam\", label=~\"$bento_label\"}[5m])), 0.001)) * 100, 0), 100) or vector(100)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "── ENTREGAS POR OUTPUT AO LONGO DO TEMPO ──",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Eventos Entregues por Output (msg/s)",
      "description": "Taxa de envio por output ao longo do tempo. Para MULTIWAY (SENTRY), reflete o rate limit.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "sum(rate(renavam_rabbitmq_sentry_sent_total{destination=~\"$destination\", path!~\".*processors\\.2.*\"}[1m])) or sum(rate(renavam_rabbitmq_sentry_sent_total{empresa=\"7LAN\", path!~\".*processors\\.2.*\"}[1m]))",
          "legendFormat": "SENTRY (RabbitMQ)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        },
        {
          "expr": "sum(rate(renavam_http_navegantes_sent_total{destination=~\"$destination\"}[1m]))",
          "legendFormat": "NAVEGANTES (HTTP)",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        },
        {
          "expr": "sum(rate(renavam_kafka_sspgo_sent_total{destination=~\"$destination\"}[1m]))",
          "legendFormat": "SSP/GO (Kafka)",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        },
        {
          "expr": "(clamp_min(sum(rate(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[1m])) - sum(rate(renavam_rabbitmq_sentry_sent_total{empresa=\"MULTIWAY\", path!~\".*processors\\.2.*\"}[1m])), 0)) or sum(rate(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[1m]))",
          "legendFormat": "Rate Limited",
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "msgps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SENTRY (RabbitMQ)" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "NAVEGANTES (HTTP)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SSP/GO (Kafka)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Rate Limited" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Distribuição por Output",
      "description": "Proporção de eventos entregues por output no período selecionado.",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 7 },
      "targets": [
        {
          "expr": "sum(increase(renavam_rabbitmq_sentry_sent_total{destination=~\"$destination\", path!~\".*processors\\.2.*\"}[$__range])) or sum(increase(renavam_rabbitmq_sentry_sent_total{empresa=\"7LAN\", path!~\".*processors\\.2.*\"}[$__range]))",
