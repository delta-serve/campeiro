        {
          "expr": "clamp_max(sum(increase(renavam_rabbitmq_sentry_sent_total{empresa=\"MULTIWAY\", path!~\".*processors\\.2.*\"}[$__range])) / clamp_min(sum(increase(renavam_messages_eligible_total{empresa=\"MULTIWAY\"}[$__range])), 1) * 100, 100) or vector(100)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
